# Proto-2 Environment
# Copy to .env.local for local development.

# -----------------------------------------------------------------------------
# Deployment notes
# - Local dev should use `.env.local`.
# - Hostinger production and Hostinger dev/staging should each define their own
#   environment variables in the panel. No code changes are needed to switch.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database — Postgres connection string consumed by prisma.config.ts and
# the runtime PrismaPg adapter in src/lib/prisma.ts.
# Example for local: postgresql://postgres:postgres@localhost:5432/proto2
# Example for Supabase: postgresql://<user>:<pass>@<host>:6543/postgres?pgbouncer=true&connection_limit=1
# Preferred variable:
#   DATABASE_URL
# Also supported (for host/panel compatibility):
#   SUPABASE_DB_URL or SUPABASE_POOLER_URL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proto2
# SUPABASE_DB_URL=
# SUPABASE_POOLER_URL=

# Optional: direct non-pooler URL for manual migration tasks
# (usually port 5432 on Supabase, while pooled URLs commonly use 6543)
# DIRECT_DATABASE_URL=

# -----------------------------------------------------------------------------
# Supabase client keys
# For browser usage, set NEXT_PUBLIC_* values.
# This app also accepts SUPABASE_URL / SUPABASE_ANON_KEY and maps them.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# AI / agent runtime
# -----------------------------------------------------------------------------
# Optional: OpenAI key for real agent LLM calls (demo mode works without it)
OPENAI_API_KEY=

# Optional: Future Tencent memory credentials
TENCENT_API_KEY=
TENCENT_BASE_URL=

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Proto-2
